{
  "name": "@reaatech/hybrid-rag-evaluation",
  "version": "2.0.0",
  "description": "Evaluation runner, ablation studies, and benchmarking for hybrid RAG systems",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/hybrid-rag.git",
    "directory": "packages/hybrid-rag-evaluation"
  },
  "homepage": "https://github.com/reaatech/hybrid-rag/tree/main/packages/hybrid-rag-evaluation#readme",
  "bugs": {
    "url": "https://github.com/reaatech/hybrid-rag/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/hybrid-rag": "workspace:*",
    "@reaatech/hybrid-rag-pipeline": "workspace:*",
    "@reaatech/hybrid-rag-retrieval": "workspace:*",
    "@reaatech/hybrid-rag-observability": "workspace:*",
    "@reaatech/agent-budget-types": "^0.1.1",
    "@reaatech/agent-budget-pricing": "^0.1.1",
    "@reaatech/agent-budget-spend-tracker": "^0.1.1",
    "@reaatech/agent-budget-engine": "^0.1.1",
    "@reaatech/guardrail-chain": "^0.1.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}

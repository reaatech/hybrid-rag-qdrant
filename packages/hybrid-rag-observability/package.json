{
  "name": "@reaatech/hybrid-rag-observability",
  "version": "2.0.0",
  "description": "Structured logging, tracing, and metrics for hybrid RAG systems",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/hybrid-rag.git",
    "directory": "packages/hybrid-rag-observability"
  },
  "homepage": "https://github.com/reaatech/hybrid-rag/tree/main/packages/hybrid-rag-observability#readme",
  "bugs": {
    "url": "https://github.com/reaatech/hybrid-rag/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/hybrid-rag": "workspace:*",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}

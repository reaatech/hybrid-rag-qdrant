{
  "name": "@reaatech/hybrid-rag-mcp-server",
  "version": "0.1.0",
  "description": "MCP server with 41+ tools for hybrid RAG integration with agent-mesh",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/hybrid-rag-qdrant.git",
    "directory": "packages/hybrid-rag-mcp-server"
  },
  "homepage": "https://github.com/reaatech/hybrid-rag-qdrant/tree/main/packages/hybrid-rag-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/reaatech/hybrid-rag-qdrant/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/hybrid-rag": "workspace:*",
    "@reaatech/hybrid-rag-pipeline": "workspace:*",
    "@reaatech/hybrid-rag-evaluation": "workspace:*",
    "@reaatech/hybrid-rag-observability": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}

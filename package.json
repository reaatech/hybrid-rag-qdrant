{
  "name": "hybrid-rag-qdrant",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade hybrid RAG reference implementation with vector + BM25 + reranker, benchmarked chunking strategies, evaluation frameworks, and ablation studies",
  "type": "module",
  "scripts": {
    "build": "pnpm install && turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "keywords": [
    "rag",
    "hybrid-retrieval",
    "qdrant",
    "bm25",
    "reranker",
    "evaluation",
    "benchmarking",
    "mcp"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/hybrid-rag-qdrant.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/hybrid-rag-qdrant/issues"
  },
  "homepage": "https://github.com/reaatech/hybrid-rag-qdrant#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.18",
      "ip-address": ">=10.1.1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.28.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.6",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
